; Engine configuration file.
; FlexSim-like discrete-event 3D factory simulator
; Godot 4.x

config_version=5

[application]

config/name="FlexSim-like Simulator (Godot)"
config/description="離散事象シミュレーション：Source→Queue→Processor→Conveyor→Sink とアイテムの流れ、オペレータ資源、稼働率統計を3Dで可視化。"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"
boot_splash/show_image=false
boot_splash/bg_color=Color(0.070588, 0.078431, 0.101961, 1)

[autoload]

Rng="*res://scripts/RngStreams.gd"
Sim="*res://scripts/Sim.gd"
Dist="*res://scripts/Distributions.gd"
Assets="*res://scripts/AssetLoader.gd"
Scripts="*res://scripts/ScriptEngine.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="mobile"
environment/defaults/default_clear_color=Color(0.08, 0.09, 0.12, 1)

[physics]

common/enable_pause_aware_picking=true
