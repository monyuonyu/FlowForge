{
	"meta": {
		"title": "AGV Congestion (capacity-1 shared edge)",
		"description": "Three production lines each hand finished items to an AGV fleet (3 transporters) that must cross a single shared corridor edge A->B (length 30) to reach the sink. The edge has capacity 1, so transporters serialize on it (single-lane, FIFO) and the delivery lead time rises versus the free-flow case. Remove network.edge_capacities (uncapacitated edge) to get the uncongested baseline. Reuses the [agv-traffic]/[agv-cap] congestion engine.",
		"expected": {
			"transporters": 3,
			"edge": "A-B",
			"edge_capacity": 1,
			"edge_length": 30.0,
			"transporter_speed": 5.0,
			"free_leg_time": 6.0,
			"claim": "mean time-in-system (lead time) with edge_capacity=1 is greater than with an uncapacitated edge (free flow)",
			"tolerance": "congested_lead > freeflow_lead (strict); both sinks deliver > 0 items",
			"measure": "Sink.avg_time_in_system(): congested run > free-flow run"
		}
	},
